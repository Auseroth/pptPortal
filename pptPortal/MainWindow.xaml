<Window x:Class="pptPortal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pptPortal"
        mc:Ignorable="d"
        Title="PPT Portal - Remote PowerPoint Uploader" Height="350" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Settings Button -->
        <Grid Grid.Row="0" Background="#FF2C3E50" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="PPT Portal" 
                       FontSize="24" FontWeight="Bold" 
                       Foreground="White" 
                       Margin="20,15,0,15" VerticalAlignment="Center"/>

            <Button Grid.Column="1" Content="⚙ Settings" 
                    Width="100" Height="35" Margin="0,0,20,0"
                    Command="{Binding OpenSettingsCommand}"
                    Background="#FF34495E" Foreground="White"
                    BorderThickness="0" FontSize="14" Cursor="Hand"/>
        </Grid>

        <!-- Main Content -->
        <StackPanel Grid.Row="1" Margin="40,20,40,20" VerticalAlignment="Center">
            <!-- Profile Info -->
            <TextBlock Text="{Binding CurrentProfileName, StringFormat='Current Profile: {0}'}" 
                       FontSize="14" FontWeight="SemiBold" 
                       Margin="0,0,0,20" 
                       Foreground="#FF7F8C8D"
                       HorizontalAlignment="Center"/>

            <!-- File Selection -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" 
                         Text="{Binding SelectedFilePath, Mode=OneWay}" 
                         IsReadOnly="True" 
                         Height="40" 
                         VerticalContentAlignment="Center"
                         Padding="10,0"
                         FontSize="13"
                         Background="#FFF5F5F5"/>

                <Button Grid.Column="1" Content="Browse..." 
                        Width="100" Height="40" Margin="10,0,0,0"
                        Command="{Binding BrowseFileCommand}"
                        Background="#FF3498DB" Foreground="White"
                        BorderThickness="0" FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>
            </Grid>

            <!-- Upload Button -->
            <Button Content="Upload to Target" 
                    Height="50" 
                    Command="{Binding UploadFileCommand}"
                    Background="#FF27AE60" Foreground="White"
                    BorderThickness="0" FontSize="16" FontWeight="Bold" Cursor="Hand"
                    IsEnabled="{Binding IsUploading, Converter={StaticResource InverseBoolConverter}}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="5"
                                            BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF229954"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FFBDC3C7"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#FFECF0F1" BorderBrush="#FFBDC3C7" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" 
                       Margin="15,10" 
                       FontSize="12" 
                       Foreground="#FF7F8C8D"/>
        </Border>
    </Grid>
</Window>

