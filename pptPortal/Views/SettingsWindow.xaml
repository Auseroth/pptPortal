<Window x:Class="pptPortal.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - PPT Portal" Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Settings" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Credential Storage Mode -->
        <GroupBox Grid.Row="1" Header="Credential Storage Mode" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <RadioButton x:Name="DPAPIRadioButton" Content="DPAPI (Windows Data Protection API) - Default" 
                             IsChecked="{Binding UseDPAPI}" Margin="0,0,0,10"
                             ToolTip="Encrypts credentials using Windows DPAPI (machine-scope)"/>
                <RadioButton x:Name="CredManagerRadioButton" Content="Windows Credential Manager" 
                             IsChecked="{Binding UseCredentialManager}"
                             ToolTip="Stores credentials in Windows Credential Manager vault"/>
            </StackPanel>
        </GroupBox>

        <!-- Profiles List -->
        <GroupBox Grid.Row="2" Header="Target Profiles" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- DataGrid -->
                <DataGrid x:Name="ProfilesDataGrid" 
                          Grid.Row="0"
                          ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          IsReadOnly="True"
                          Margin="0,0,0,10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Profile Name" Binding="{Binding ProfileName}" Width="150"/>
                        <DataGridTextColumn Header="Computer" Binding="{Binding ComputerIdentifier}" Width="150"/>
                        <DataGridTextColumn Header="UNC Path" Binding="{Binding TargetUncPath}" Width="*"/>
                        <DataGridTextColumn Header="Target File" Binding="{Binding TargetFileName}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Profile Buttons -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Add" Width="80" Margin="0,0,10,0" Command="{Binding AddProfileCommand}"/>
                    <Button Content="Edit" Width="80" Margin="0,0,10,0" Command="{Binding EditProfileCommand}"/>
                    <Button Content="Remove" Width="80" Command="{Binding RemoveProfileCommand}"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Info -->
        <TextBlock Grid.Row="3" Margin="0,0,0,15" TextWrapping="Wrap" Foreground="Gray" FontSize="11">
            Note: Administrator privileges are required to save configuration changes. 
            Credentials are stored securely using the selected storage method.
        </TextBlock>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="100" Margin="0,0,10,0" Command="{Binding SaveCommand}" IsDefault="True"/>
            <Button Content="Cancel" Width="100" Command="{Binding CancelCommand}" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
